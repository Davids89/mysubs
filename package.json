    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "turbo": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  }
}
