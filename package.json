{
  "name": "mysubs",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "docker:down": "docker compose down",
    "docker:up": "docker compose up --build",
