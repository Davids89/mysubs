{
  "name": "@mysubs/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "lint": "eslint src spec --max-warnings=0",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "DATABASE_URL=postgresql://mysubs:mysubs@localhost:5432/mysubs?schema=public prisma generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "latest",
    "pg": "^8.21.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/supertest": "latest",
    "prisma": "^7.8.0",
    "supertest": "latest",
    "tsx": "latest",
    "typescript": "^5.9.3",
    "vitest": "latest"
  }
}
